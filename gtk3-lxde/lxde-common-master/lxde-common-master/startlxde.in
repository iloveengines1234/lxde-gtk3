#!/bin/sh

# Setup base XDG environment directory specifications if unset
if [ -z "$XDG_CONFIG_HOME" ]; then
    export XDG_CONFIG_HOME="$HOME/.config"
fi

if [ -z "$XDG_DATA_HOME" ]; then
    export XDG_DATA_HOME="$HOME/.local/share"
fi

# Ensure the existence of openbox configuration blueprints
OPENBOX_CONF_DIR="$XDG_CONFIG_HOME/openbox"
if [ ! -f "$OPENBOX_CONF_DIR/lxde-rc.xml" ]; then
    mkdir -p "$OPENBOX_CONF_DIR"
    cp "@sysconfdir@/xdg/openbox/LXDE/rc.xml" "$OPENBOX_CONF_DIR/lxde-rc.xml"
fi

# Ensure the existence of the localized user 'Desktop' folder layout
if [ -e "$XDG_CONFIG_HOME/user-dirs.dirs" ]; then
    . "$XDG_CONFIG_HOME/user-dirs.dirs"
else
    XDG_DESKTOP_DIR="$HOME/Desktop"
fi
mkdir -p "$XDG_DESKTOP_DIR"

# Ensure the existence of the primary user local applications directory path
USER_APPS_DIR="$XDG_DATA_HOME/applications"
mkdir -p "$USER_APPS_DIR"

# Clean up window properties after Display Managers (forces workspace layout updates)
xprop -root -remove _NET_NUMBER_OF_DESKTOPS -remove _NET_DESKTOP_NAMES -remove _NET_CURRENT_DESKTOP 2> /dev/null

# Fixed: Upgraded toolkit integration properties to prefer GTK 3 backends natively
export SAL_USE_VCLPLUGIN=gtk3

# Launch DBus tracking session bus daemons dynamically if needed
# Fixed: Swapped fragile legacy 'which' calls for robust 'command -v' execution checks
if command -v dbus-launch >/dev/null 2>&1 && [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
    if [ -z "$XDG_RUNTIME_DIR" ] || [ ! -S "$XDG_RUNTIME_DIR/bus" ] || [ ! -O "$XDG_RUNTIME_DIR/bus" ]; then
        eval "$(dbus-launch --sh-syntax --exit-with-session)"
    fi
fi

export XDG_MENU_PREFIX="lxde-"
export XDG_CURRENT_DESKTOP="LXDE"

# Bootstrap and pass explicit runtime execution context to the primary session binary
exec "@prefix@/bin/lxsession" -s LXDE -e LXDE