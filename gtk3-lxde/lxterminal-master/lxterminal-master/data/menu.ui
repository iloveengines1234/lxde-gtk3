      </item>
      <item>
        <attribute name="label" translatable="yes">Move Tab Left</attribute>
        <attribute name="action">win.Tabs_MoveTabLeft</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Move Tab Right</attribute>
        <attribute name="action">win.Tabs_MoveTabRight</attribute>
      </item>
    </submenu>
    
    <submenu>
      <attribute name="label" translatable="yes">Help</attribute>
      <item>
        <attribute name="label" translatable="yes">About</attribute>
        <attribute name="action">win.Help_About</attribute>
