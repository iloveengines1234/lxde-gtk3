      </item>
      <section>
        <item>
          <attribute name="label" translatable="yes">Zoom In</attribute>
          <attribute name="action">win.Edit_ZoomIn</attribute>
        </item>
        <item>
          <attribute name="label" translatable="yes">Zoom Out</attribute>
          <attribute name="action">win.Edit_ZoomOut</attribute>
        </item>
        <item>
          <attribute name="label" translatable="yes">Zoom Reset</attribute>
          <attribute name="action">win.Edit_ZoomReset</attribute>
        </item>
      </section>
      <section>
        <item>
          <attribute name="label" translatable="yes">Preferences</attribute>
          <attribute name="action">win.Edit_Preferences</attribute>
        </item>
      </section>
    </submenu>
    
    <submenu>
      <attribute name="label" translatable="yes">Tabs</attribute>
      <item>
        <attribute name="label" translatable="yes">Name Tab</attribute>
        <attribute name="action">win.Tabs_NameTab</attribute>
      </item>
      <item>
