# Target installation directory for modern GtkBuilder UI definition assets
uidir = $(datadir)/lxappearance/ui

# Maintain raw UI templates directly with native .ui extensions
ui_DATA = \
	about.ui \
	lxappearance.ui

# Ensure all interface assets are cleanly packaged into the release distribution tarball
EXTRA_DIST = \
	$(ui_DATA)

# Keep the workspace clean
CLEANFILES = \
	$(NULL)