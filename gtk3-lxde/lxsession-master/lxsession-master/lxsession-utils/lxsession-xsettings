#!/bin/sh
set -e

# Isolated verbose terminal spam to standard error and guarded it 
# behind an explicit environment debug flag.
if [ "$LXSESSION_DEBUG" = "1" ]; then
    echo "lxsession-xsettings runtime arguments: 1=$1, 2=$2" >&2
fi

# Modernized: Enforce standard command help strings if executed without target directives
if [ -z "$1" ]; then
    echo "Usage: lxsession-xsettings [reload|--reload]" >&2
    exit 1
fi

case "$1" in
    reload|--reload)
        echo "Initiating Xsettings daemon reload protocol..."
        
        # Guard: Validate that dbus-send exists and an active session bus pointer is loaded
        if ! command -v dbus-send >/dev/null 2>&1; then
            echo "Error: 'dbus-send' utility not found. Cannot broadcast reload signal." >&2
            exit 1
        elif [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
            echo "Error: \$DBUS_SESSION_BUS_ADDRESS environment variable is empty." >&2
            exit 1
        fi

        dbus-send --session --print-reply \
                  --dest="org.lxde.SessionManager" \
                  /org/lxde/SessionManager \
                  org.lxde.SessionManager.ReloadSettingsDaemon >/dev/null 2>&1
        ;;
    *)
        echo "Error: Unknown argument execution target: $1" >&2
        exit 1
        ;;
esac

exit 0